import React, { useState } from 'react';
import { FileText, Copy, Check, Eye, EyeOff, Info, CheckCircle } from 'lucide-react';

export default function PreviewPanel({ data }) {
  const [showOriginal, setShowOriginal] = useState(false);
  const [copied, setCopied] = useState(false);

  if (!data) return null;

  const { 
    fileInfo, 
    documentType, 
    documentTitle,
    summary, 
    keyFindings,
    metadata,
    confidence, 
    model, 
    cached, 
    originalContent 
  } = data;

  const handleCopy = async () => {
    try {
      await navigator.clipboard.writeText(originalContent);
      setCopied(true);
      setTimeout(() => setCopied(false), 2000);
    } technical_spec: 'Technical Specification',
      user_manual: 'User Manual',
      report: 'Report',
      general: 'General Document',
    };
    return labels[type] || type;
  };

  const getDocTypeColor = (type) => {
    const colors = {
      api_docs: 'bg-blue-100 text-blue-700',
      setup_guide: 'bg-green-100 text-green-700',
      config: 'bg-purple-100 text-purple-700',
      legal: 'bg-red-100 text-red-700',
      technical_spec: 'bg-indigo-100 text-indigo-700',
      user_manual: 'bg-yellow-100 text-yellow-700',
      report: 'bg-pink-100 text-pink-700',
      general: 'bg-gray-100 text-gray-700',
    };
    return colors[type] || 'bg-gray-100 text-gray-700'
  };

  const getDocTypeLabel = (type) => {
    const labels = {
      api_docs: 'API Documentation',
      setup_guide: 'Setup Guide',
      config: 'Configuration',
      legal: 'Legal Document', flex-1">
            <FileText className="w-6 h-6 text-primary-600 mt-1 flex-shrink-0" />
            <div className="flex-1">
              <h3 className="text-xl font-bold text-gray-900">
                {documentTitle || fileInfo.name}
              </h3>
              <p className="text-sm text-gray-600 mt-1">
                {fileInfo.type} • {(fileInfo.size / 1024).toFixed(2)} KB
                {fileInfo.pages && ` • ${fileInfo.pages} pages`}
              </p>
            </div>
          </div>

          <div className="flex items-center gap-2">
            {cached && (
              <span className="px-3 py-1 bg-purple-100 text-purple-700 text-xs font-medium rounded-full">
                ⚡ Cached
              </span>
            )}
          </div>
        </div>

        {/* Metadata */}
        <div className="grid grid-cols-2 gap-4 pt-4 border-t border-gray-200">
          <div>
            <span className="text-sm text-gray-600">Document Type</span>
            <p className="mt-1">
              <span className={`inline-block px-3 py-1 rounded-full text-sm font-medium ${getDocTypeColor(documentType)}`}>
                {getDocTypeLabel(documentType)}
              </span>
            </p>
          </div>
          <div>
            <span className="text-sm text-gray-600">AI Confidence</span>
            <p className="mt-1">
              <span className={`inline-flex items-center gap-1 px-2 py-1 rounded text-sm font-medium ${getConfidenceColor(confidence)}`}>
                {(confidence * 100).toFixed(0)}%
              </span>
            </p>
          </div>
        </div>

        {/* Tags */}
        {metadata?.tags && metadata.tags.length > 0 && (
          <div className="mt-4 pt-4 border-t border-gray-200">
            <span className="text-sm text-gray-600 mb-2 block">Tags</span>
            <div className="flex flex-wrap gap-2">
              {metadata.tags.map((tag, idx) => (
                <span key={idx} className="px-2 py-1 bg-gray-100 text-gray-700 text-xs rounded">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        )}

        {confidence < 0.6 && (
          <div className="mt-4 p-3 bg-yellow-50 border border-yellow-200 rounded-lg flex items-start gap-2">
            <Info className="w-4 h-4 text-yellow-600 mt-0.5 flex-shrink-0" />
            <p className="text-sm text-yellow-800">
              AI is uncertain about the document structure. The generated UI may not be optimal.
            </p>
          </div>
        )}
      </div>

      {/* Summary Card */}
      {summary && (
        <div className="card">
          <h4 className="font-semibold text-gray-900 mb-3 flex items-center gap-2">
            <Info className="w-5 h-5 text-primary-600" />
            Summary
          </h4>
          <p className="text-gray-700 leading-relaxed">{summary}</p>
        </div>
      )}

      {/* Key Findings */}
      {keyFindings && keyFindings.length > 0 && (
        <div className="card">
          <h4 className="font-semibold text-gray-900 mb-3 flex items-center gap-2">
            <CheckCircle className="w-5 h-5 text-green-600" />
            Key Findings
          </h4>
          <ul className="space-y-2">
            {keyFindings.map((finding, idx) => (
              <li key={idx} className="flex items-start gap-2">
                <span className="text-primary-600 font-bold">•</span>
                <span className="text-gray-700">{finding}</span>
              </li>
            ))}
          </ul
        </div>

        {confidence < 0.6 && (
          <div className="mt-4 p-3 bg-yellow-50 border border-yellow-200 rounded-lg flex items-start gap-2">
            <Info className="w-4 h-4 text-yellow-600 mt-0.5 flex-shrink-0" />
            <p className="text-sm text-yellow-800">
              AI is uncertain about the document structure. The generated UI may not be optimal.
            </p>
          </div>
        )}
      </div>

      {/* Summary Card */}
      {summary && (
        <div className="card">
          <h4 className="font-semibold text-gray-900 mb-2">Summary</h4>
          <p className="text-gray-700 leading-relaxed">{summary}</p>
        </div>
      )}

      {/* Original Content Card */}
      <div className="card">
        <div className="flex items-center justify-between mb-3">
          <h4 className="font-semibold text-gray-900">Original Content</h4>
          <div className="flex items-center gap-2">
            <button
              onClick={handleCopy}
              className="btn btn-secondary text-sm flex items-center gap-2"
            >
              {copied ? (
                <>
                  <Check className="w-4 h-4" />
                  Copied
                </>
              ) : (
                <>
                  <Copy className="w-4 h-4" />
                  Copy
                </>
              )}
            </button>
            <button
              onClick={() => setShowOriginal(!showOriginal)}
              className="btn btn-secondary text-sm flex items-center gap-2"
            >
              {showOriginal ? (
                <>
                  <EyeOff className="w-4 h-4" />
                  Hide
                </>
              ) : (
                <>
                  <Eye className="w-4 h-4" />
                  Show
                </>
              )}
            </button>
          </div>
        </div>

        {showOriginal && (
          <div className="mt-3 max-h-96 overflow-y-auto">
            <pre className="text-sm whitespace-pre-wrap text-gray-700 bg-gray-50 p-4 rounded-lg border border-gray-200">
              {originalContent}
            </pre>
          </div>
        )}
      </div>

      {/* Model Info */}
      <div className="text-xs text-gray-500 text-center">
        Analyzed by {model || 'AI'}
      </div>
    </div>
  );
}
